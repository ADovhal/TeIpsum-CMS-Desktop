<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.teipsum.shopcmsdesktop.auth.controller.LoginController"
      styleClass="login-root"
      alignment="CENTER"
      spacing="0"
      stylesheets="@login.css">

    <VBox styleClass="login-card" spacing="24" maxWidth="420">

        <VBox spacing="6" alignment="CENTER">
            <Label text="👑" style="-fx-font-size: 48px;"/>
            <Label text="Shop CMS" styleClass="login-title"/>
            <Label text="Admin Panel" styleClass="login-subtitle"/>
        </VBox>

        <VBox spacing="16">
            <VBox spacing="6">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="admin@example.com"
                           styleClass="field-input"/>
                <Label fx:id="emailError" styleClass="field-error"
                       visible="false" managed="false"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               styleClass="field-input"/>
                <Label fx:id="passwordError" styleClass="field-error"
                       visible="false" managed="false"/>
            </VBox>
        </VBox>

        <Label fx:id="generalError" styleClass="general-error"
               visible="false" managed="false" wrapText="true"/>

        <Button fx:id="loginButton"
                text="Sign In"
                styleClass="login-button"
                maxWidth="Infinity"
                onAction="#handleLogin"/>

        <Label fx:id="apiUrlLabel" styleClass="api-url-label"/>

    </VBox>
</VBox>
