<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.teipsum.shopcmsdesktop.ui.MainWindow"
            prefWidth="1200" prefHeight="700">

    <top>
        <HBox styleClass="form-card" spacing="16" alignment="CENTER_LEFT"
              style="-fx-padding: 16px 24px;">
            <Label text="👑 Shop CMS" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Add Product" styleClass="submit-button"
                    onAction="#handleAddProduct"/>
            <Button text="Logout" styleClass="cancel-button"
                    onAction="#handleLogout"/>
            <Button text="+ Add Admin" styleClass="secondary-button"
                    onAction="#handleAddAdmin"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24px;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Products" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⟳ Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
            </HBox>

            <Label fx:id="errorBanner" styleClass="error-banner"
                   visible="false" managed="false" wrapText="true"/>
            <Label fx:id="successBanner" styleClass="success-banner"
                   visible="false" managed="false" wrapText="true"/>

            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="No products found"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colTitle"    text="Title"     prefWidth="220"/>
                    <TableColumn fx:id="colCategory" text="Category"  prefWidth="110"/>
                    <TableColumn fx:id="colGender"   text="Gender"    prefWidth="90"/>
                    <TableColumn fx:id="colPrice"    text="Price"     prefWidth="90"/>
                    <TableColumn fx:id="colDiscount" text="Discount"  prefWidth="90"/>
                    <TableColumn fx:id="colAvail"    text="Available" prefWidth="90"/>
                    <TableColumn fx:id="colActions"  text="Actions"   prefWidth="160"/>
                </columns>
            </TableView>

            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="prevButton" text="← Prev"
                        onAction="#handlePrev" styleClass="secondary-button"
                        disable="true"/>
                <Label fx:id="pageLabel" text="Page 1"/>
                <Button fx:id="nextButton" text="Next →"
                        onAction="#handleNext" styleClass="secondary-button"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>